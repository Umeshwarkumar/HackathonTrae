# IntentLock + ArmorIQ Configuration

# ============================================================
# Gemini API Configuration
# ============================================================
# Used for AI-powered intent contract generation
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# ArmorIQ SDK Configuration (REAL SDK Integration)
# ============================================================
# API Key for ArmorIQ governance layer
# Get your key from: https://console.armoriq.io/api-keys
ARMORIQ_API_KEY=your_armoriq_api_key_here

# ArmorIQ API Base URL
# Default: https://api.armoriq.io/v1
# For self-hosted: https://your-armoriq-instance/api/v1
ARMORIQ_API_URL=https://api.armoriq.io/v1

# ArmorIQ Client ID (identifies this IntentLock instance)
# Used for audit trail tracking and policy routing
ARMORIQ_CLIENT_ID=intentlock-client

# Optional: ArmorIQ environment (production, staging, development)
ARMORIQ_ENVIRONMENT=production
